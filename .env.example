# Supabase (CMS + Storage; necesario en producción)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Navegador (solo publishable/anónima; necesaria para upload directo a Storage y esquivar límites de payload en Vercel)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Opcional — mismo bucket cliente/servidor (por defecto: cms)
# SUPABASE_STORAGE_BUCKET=cms
# NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=cms

# En Supabase ejecuta los SQL en supabase/migrations/ — incluye products + cms_documents + bucket cms
